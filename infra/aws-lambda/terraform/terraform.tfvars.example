aws_region      = "us-east-1"
app_name        = "elecbidspec-ai"
frontend_origin = "https://elecbidspec-ai.pages.dev"

# Do not commit real tfvars. Use a Neon pooled connection string for Lambda.
database_url    = "postgresql+psycopg://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
lambda_zip_path = "/absolute/path/to/.build/elecbidspec-ai-backend.zip"

bootstrap_database_on_startup = true
bedrock_proposals_enabled     = false
bedrock_model_id              = "us.anthropic.claude-sonnet-4-6"
bedrock_max_tokens            = 1800
bedrock_temperature           = 0.2
sam_gov_api_key               = ""
admin_api_token               = ""
auth_required                 = false
auth_admin_email              = ""
auth_admin_password           = ""
auth_user_email               = ""
auth_user_password            = ""
nypa_api_subscription_key     = ""
