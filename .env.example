# Backend
DATABASE_URL=postgresql+psycopg://elecbidspec:elecbidspec@db:5432/elecbidspec
DATABASE_DISABLE_POOL=false
FRONTEND_ORIGIN=http://localhost:3000
UPLOAD_DIR=/tmp/elecbidspec_uploads
UPLOAD_BUCKET=
UPLOAD_PREFIX=uploads

# Optional serverless startup bootstrap.
# Useful for first Lambda deploys; set false after the database is initialized if cold-start speed matters.
BOOTSTRAP_DATABASE_ON_STARTUP=false
RUN_MIGRATIONS_ON_STARTUP=true
SEED_DATABASE_ON_STARTUP=true
WORKER_MAX_JOBS_PER_RUN=5

# Optional live SAM.gov ingestion.
# The app works without this key by using seed data and manual uploads.
SAM_GOV_API_KEY=
SAM_GOV_API_BASE_URL=https://api.sam.gov/opportunities/v2/search

# Optional AWS Bedrock proposal generation.
# If disabled or unavailable, the app uses deterministic proposal generation.
BEDROCK_PROPOSALS_ENABLED=false
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_REGION=us-east-1
BEDROCK_MAX_TOKENS=2500
BEDROCK_TEMPERATURE=0.2
# AWS credentials are read by boto3 from the normal environment/role chain.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
